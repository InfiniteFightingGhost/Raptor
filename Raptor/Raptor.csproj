<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Nullable>enable</Nullable>
    <OptimizationPreference>Speed</OptimizationPreference>
    <Optimize>true</Optimize>
    <PublishAot>true</PublishAot>
    <IsAotCompatible>true</IsAotCompatible>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <PackageId>Raptor.VM</PackageId>
    <Version>1.0.0-alpha</Version>
    <Authors>InfiniteFightingGhost</Authors>
    <Description>Fast, zero-allocation register-based VM and scripting engine for .NET 10.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/InfiniteFightingGhost/Raptor</RepositoryUrl>
    <PackageTags>vm;scripting;game-engine;compiler;bytecode;dotnet10</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Raptor.Tests" />
    <Compile Remove="Examples\**" />
  </ItemGroup>
</Project>
